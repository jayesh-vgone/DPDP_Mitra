# ── Environment ──────────────────────────────────────────────────────────────
# "development" or "production". The app's own auth is server-side session
# cookies (enforced per-route), so production is safe — the JWT middleware is a
# reserved hook that skips all first-party routes either way.
APP_ENV=development

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256

# ── Session cookie attributes ────────────────────────────────────────────────
# Local dev (same-origin http): keep the relaxed defaults below.
# Split deployment (Vercel frontend + Render backend on different domains):
#   COOKIE_SECURE=true
#   COOKIE_SAMESITE=none
# Without these, the browser will NOT send the session cookie cross-site and
# login will appear to "succeed" but every following request is treated as 401.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ── LLM provider ─────────────────────────────────────────────────────────────
# Options: groq | mock
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_key_here
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# ── STT provider ─────────────────────────────────────────────────────────────
# Options: groq | mock
STT_PROVIDER=groq
GROQ_STT_MODEL=whisper-large-v3

# ── TTS provider ─────────────────────────────────────────────────────────────
# Phase 2: browser TTS (frontend uses SpeechSynthesis). No key needed.
# Phase 5: swap to sarvam.
TTS_PROVIDER=browser

# ── Embeddings ───────────────────────────────────────────────────────────────
# Options: cohere | mock  (mock = random vectors, no key needed)
EMBEDDING_PROVIDER=cohere
COHERE_API_KEY=your_cohere_key_here

# ── Database ──────────────────────────────────────────────────────────────────
# Required for RAG retrieval and (Phase 4) history persistence.
# Start PostgreSQL+pgvector with: docker-compose up -d
DATABASE_URL=postgresql://dpdp:dpdp@localhost:5433/dpdp

# ── Email (OTP verification) ──────────────────────────────────────────────────
# Resend API key for sending OTP emails.  Get a free key at https://resend.com
RESEND_API_KEY=your_resend_key_here
# Set to true once a real sending domain is verified in Resend and the `from`
# address in backend/providers/email_sender.py is updated to use that domain.
# While false: registration issues a session immediately (no OTP), and login
# skips the email_verified check entirely — exactly as before Phase 9.
EMAIL_VERIFICATION_ENABLED=false

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Production: set to your Vercel URL, e.g. https://eduprivacy.vercel.app
# (Not needed if you use the Vercel rewrite/proxy in DEPLOY.md — requests are
#  then same-origin and never trigger CORS.)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
