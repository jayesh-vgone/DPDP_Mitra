# ── Environment ──────────────────────────────────────────────────────────────
# "development" skips JWT verification (safe for local dev only).
# Set to "production" on the VM and supply a real JWT_SECRET.
APP_ENV=development

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256

# ── LLM provider ─────────────────────────────────────────────────────────────
# Options: groq | mock
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_key_here
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# ── STT provider ─────────────────────────────────────────────────────────────
# Options: groq | mock
STT_PROVIDER=groq
GROQ_STT_MODEL=whisper-large-v3

# ── TTS provider ─────────────────────────────────────────────────────────────
# Phase 2: browser TTS (frontend uses SpeechSynthesis). No key needed.
# Phase 5: swap to sarvam.
TTS_PROVIDER=browser

# ── Embeddings ───────────────────────────────────────────────────────────────
# Options: cohere | mock  (mock = random vectors, no key needed)
EMBEDDING_PROVIDER=cohere
COHERE_API_KEY=your_cohere_key_here

# ── Database ──────────────────────────────────────────────────────────────────
# Required for RAG retrieval and (Phase 4) history persistence.
# Start PostgreSQL+pgvector with: docker-compose up -d
DATABASE_URL=postgresql://dpdp:dpdp@localhost:5433/dpdp

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
