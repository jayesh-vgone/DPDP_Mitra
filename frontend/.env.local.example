# Local development: point at your local backend.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Set to "mock" to use the built-in mock API (no backend needed):
# NEXT_PUBLIC_API_URL=mock

# ── Production (Vercel) ───────────────────────────────────────────────────────
# RECOMMENDED: use the same-origin proxy (frontend/vercel.json rewrites /api/* to
# the Render backend) so session cookies stay first-party. Then set:
#   NEXT_PUBLIC_API_URL=/api
#
# ALTERNATIVE: call the Render backend directly (cross-origin). Then set:
#   NEXT_PUBLIC_API_URL=https://<your-backend>.onrender.com
# and the backend must run COOKIE_SAMESITE=none, COOKIE_SECURE=true, and list the
# Vercel URL in CORS_ORIGINS. (Note: cross-site cookies are blocked by Safari and
# being phased out in Chrome — prefer the proxy.)
#
# NEXT_PUBLIC_* values are baked in at BUILD time — changing this requires a redeploy.
